UPDATE customer
SET Gender= 'Others' WHERE Gender = 'OTHER';

-- SHOW DUPLICATE ROWS IN DATASET
SELECT
CustomerID,
COUNT(*) AS COUNTA
FROM customer
GROUP BY CustomerID
having COUNT(*)>1;

-- what is the percentage of male and female customer
SELECT 
    (SUM(CASE WHEN Gender = 'Male' THEN 1 ELSE 0 END ) * 100.0 / COUNT(*)) AS Male_Percentage,
    (SUM(CASE WHEN Gender = 'Female' THEN 1 ELSE 0 END) * 100.0 / COUNT(*)) AS Female_Percentage
FROM customer;




